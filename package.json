{
  "name": "gothenburg-simulator-3d",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Göteborgs-simulatorn — a 3D Gothenburg sandbox built with React + Three.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 8100 --host 127.0.0.1",
    "typecheck": "tsgo --noEmit -p tsconfig.app.json && tsgo --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,css,json,md}\"",
    "check": "npm run typecheck && npm run lint && npm run build"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@typescript/native-preview": "^7.0.0-dev.20260702.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.11",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
